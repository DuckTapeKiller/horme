    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "node --import tsx --test test/vectorUtils.test.ts test/typeGuards.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^0.14.0",
    "@types/node": "^16.11.6",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "moment": "^2.30.1",
    "obsidian": "latest",
    "prettier": "^3.3.2",
    "style-mod": "^4.1.3",
    "tslib": "2.4.0",
    "tsx": "^4.22.4",
    "typescript": "4.9.5",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    }
